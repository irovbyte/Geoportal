<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Geoportal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">

    <style>
        /* 1. ГЛОБАЛЬНЫЕ НАСТРОЙКИ */
        body {
            background-color: #0A56C4;
            background-image: linear-gradient(135deg, #0A56C4 0%, #158296 50%, #19A332 100%) !important;
            background-attachment: fixed !important;
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
            transition: background-image 0.4s ease-in-out;
        }

        main { flex: 1; }

        /* =========================================
           СТЕКЛО (GLASSMORPHISM) ДЛЯ СВЕТЛОЙ ТЕМЫ
           ========================================= */
        .stat-card-mini,
        .inner-finance-card,
        .glass-content-panel,
        .report-main-card,
        .mockup-box,
        .donor-leaderboard,
        .donor-item,
        .map-wrapper,
        .ultra-tool-section {
            background: rgba(255, 255, 255, 0.75) !important;
            backdrop-filter: blur(25px) !important;
            -webkit-backdrop-filter: blur(25px) !important;
            border: 1px solid rgba(255, 255, 255, 0.5) !important;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1) !important;
        }

        .tab-pill {
            background: rgba(255, 255, 255, 0.6) !important;
            backdrop-filter: blur(10px) !important;
            border: 2px solid rgba(255, 255, 255, 0.8) !important;
        }
        .tab-pill.active {
            background: rgba(255, 255, 255, 0.75) !important;
            border-bottom-color: transparent !important;
        }

        /* =========================================
           ТЕМНАЯ ТЕМА (DARK MODE GLASSMORPHISM)
           ========================================= */
        body.dark-mode {
            background-image: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #064e3b 100%) !important;
        }

        body.dark-mode .stat-card-mini,
        body.dark-mode .inner-finance-card,
        body.dark-mode .glass-content-panel,
        body.dark-mode .report-main-card,
        body.dark-mode .mockup-box,
        body.dark-mode .donor-leaderboard,
        body.dark-mode .donor-item,
        body.dark-mode .map-wrapper,
        body.dark-mode .ultra-tool-section {
            background: rgba(15, 23, 42, 0.55) !important; 
            border-color: rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3) !important;
        }

        body.dark-mode .stat-card-mini.active-main-card { background: rgba(15, 23, 42, 0.8) !important; border-color: #00FF88 !important; box-shadow: 0 30px 60px rgba(0, 255, 136, 0.15) !important; }
        
        body.dark-mode .tab-pill { background: rgba(15, 23, 42, 0.4) !important; color: #94a3b8 !important; border-color: rgba(255,255,255,0.1) !important; }
        body.dark-mode .tab-pill:hover { background: rgba(15, 23, 42, 0.6) !important; }
        body.dark-mode .tab-pill.active { background: rgba(15, 23, 42, 0.55) !important; color: #ffffff !important; border-bottom-color: transparent !important; box-shadow: none !important; }

        body.dark-mode .card-value-mini, body.dark-mode .inner-value, body.dark-mode .text-dark, body.dark-mode .category-title, body.dark-mode h1, body.dark-mode h2, body.dark-mode h3, body.dark-mode h4, body.dark-mode h5 { color: #f8fafc !important; }
        body.dark-mode .card-label-mini, body.dark-mode .inner-label, body.dark-mode .text-muted, body.dark-mode p { color: #94a3b8 !important; }
        body.dark-mode .list-item-modern { background: rgba(255,255,255,0.05) !important; border-color: rgba(255,255,255,0.1) !important; }
        body.dark-mode .list-item-modern:hover { background: rgba(255,255,255,0.1) !important; border-color: #00FF88 !important; }

        /* Вспомогательные элементы карты в темной теме (Фон, Кнопки +/-, Копирайт) */
        body.dark-mode .leaflet-container { background: #0f172a !important; } /* Фон под тайлами */
        body.dark-mode .leaflet-control-attribution { background: rgba(0, 0, 0, 0.5) !important; color: rgba(255, 255, 255, 0.5) !important; }
        body.dark-mode .leaflet-control-attribution a { color: #00FF88 !important; }
        body.dark-mode .leaflet-bar a { background-color: rgba(30, 41, 59, 0.8) !important; color: white !important; border-color: rgba(255,255,255,0.1) !important; }

        /* Табы над картой */
        body.dark-mode .tool-tabs-nav { background: rgba(0, 0, 0, 0.3) !important; border-radius: 20px; padding: 8px; }
        body.dark-mode .tool-tab-btn { color: rgba(255, 255, 255, 0.6) !important; background: transparent !important; }
        body.dark-mode .tool-tab-btn.active { background: rgba(255, 255, 255, 0.1) !important; border: 1px solid rgba(255, 255, 255, 0.1) !important; color: #00FF88 !important; }


        /* =========================================
           ПРЕМИУМ ШАПКА (УЛЬТРА-ТОНКАЯ)
           ========================================= */
        .glass-header {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(25px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
            position: sticky; top: 0; z-index: 1050; 
            padding: 8px 0; 
        }

        .header-grid {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            width: 100%;
        }

        .header-left { display: flex; justify-content: flex-start; }
        .header-center { display: flex; justify-content: center; }
        .header-right { display: flex; align-items: center; gap: 12px; justify-content: flex-end; }

        .logo-text {
            font-weight: 900; font-size: 1.4rem; color: #ffffff; text-decoration: none;
            letter-spacing: 1px; display: flex; align-items: center; gap: 10px;
            transition: transform 0.3s ease;
        }
        .logo-text:hover { transform: scale(1.03); color: #ffffff; }
        .header-logo-img { height: 30px; width: auto; filter: brightness(0) invert(1); }

        .nav-menu { display: flex; gap: 20px; align-items: center; margin: 0; padding: 0; }
        .nav-link-glass {
            color: rgba(255, 255, 255, 0.85); font-weight: 700; text-transform: uppercase;
            font-size: 0.85rem; letter-spacing: 0.5px; text-decoration: none;
            position: relative; padding: 5px 0; transition: color 0.3s ease;
        }
        .nav-link-glass:hover { color: #ffffff; }
        .nav-link-glass::after {
            content: ''; position: absolute; width: 0; height: 2px;
            bottom: 0; left: 50%; background-color: #00FF88;
            transition: all 0.3s ease; transform: translateX(-50%);
        }
        .nav-link-glass:hover::after { width: 100%; }

        .btn-download { color: #00FF88 !important; font-weight: 800 !important; }
        .btn-download::after { background-color: #ffffff; }
        .btn-download:hover { color: #ffffff !important; }

        .circle-btn {
            width: 38px; height: 38px; border-radius: 50%;
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
            color: white; display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.3s ease;
        }
        .circle-btn:hover { background: rgba(255,255,255,0.25); color: #00FF88; border-color: #00FF88; transform: translateY(-2px); }

        .lang-toggle {
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
            color: white; border-radius: 100px; padding: 0 12px; height: 38px;
            display: flex; align-items: center; font-weight: 800; font-size: 0.8rem; cursor: pointer; transition: 0.3s;
            user-select: none;
        }
        .lang-toggle:hover { background: rgba(255,255,255,0.2); border-color: #00FF88; }
        .lang-toggle span.opacity-50 { margin: 0 8px; font-weight: 400; }
        .lang-active { color: #00FF88; }
        .lang-inactive { color: rgba(255,255,255,0.5); transition: color 0.3s; }
        .lang-toggle:hover .lang-inactive { color: #ffffff; }

        .btn-login {
            background: linear-gradient(90deg, #00FF88 0%, #00D4FF 100%);
            color: #000; font-weight: 800; border: none; border-radius: 100px;
            padding: 6px 20px; height: 38px; display: flex; align-items: center; justify-content: center;
            transition: 0.3s; box-shadow: 0 5px 15px rgba(0, 255, 136, 0.3); text-decoration: none; font-size: 0.85rem;
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0, 255, 136, 0.5); color: #000; }

        /* 3. ПОДВАЛ (FOOTER) */
        .glass-footer {
            background: rgba(10, 86, 196, 0.3);
            backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);
            border-top: 1px solid rgba(255, 255, 255, 0.15); padding: 25px 0; margin-top: auto;
        }
        body.dark-mode .glass-footer { background: rgba(15, 23, 42, 0.6); }

        .footer-inner { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 20px; }
        .footer-links { display: flex; gap: 30px; margin: 0; padding: 0; }
        .footer-links a { color: rgba(255,255,255,0.8); text-decoration: none; font-weight: 500; font-size: 0.95rem; transition: color 0.3s ease; display: flex; align-items: center; gap: 8px; }
        .footer-links a:hover { color: #00FF88; }
        .footer-copy { color: rgba(255,255,255,0.5); font-size: 0.85rem; font-weight: 500; margin: 0; }

        @@media (max-width: 991px) { 
            .header-center { display: none; } 
            .footer-inner { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>
    
    <script>
        if (localStorage.getItem('geoportal_theme') === 'dark') {
            document.body.classList.add('dark-mode');
        }
    </script>

    <header class="glass-header">
        <div class="container-fluid px-4">
            <div class="header-grid">
                
                <div class="header-left">
                    <a href="/" class="logo-text">
                        <img src="~/images/logo.png" alt="Logo" class="header-logo-img" />
                        GEOPORTAL
                    </a>
                </div>
                
                <div class="header-center">
                    <nav class="nav-menu">
                        <a class="nav-link-glass" href="/">Asosiy</a>
                        <a class="nav-link-glass" href="/Home/Report">Murojaat</a>
                        <a class="nav-link-glass" href="#">Statistika</a>
                        <a class="nav-link-glass" href="#">Xarita</a>
                        <a class="nav-link-glass btn-download" href="/Home/Download"><i class="bi bi-download me-1"></i> Yuklab olish</a>
                    </nav>
                </div>

                <div class="header-right">
                    <div class="circle-btn" id="theme-toggle" title="Mavzuni o'zgartirish">
                        <i class="bi bi-moon-fill" id="theme-icon"></i>
                    </div>

                    <div class="lang-toggle" id="lang-toggle">
                        <span id="lang-uz" class="lang-active">UZ</span>
                        <span class="opacity-50">/</span>
                        <span id="lang-ru" class="lang-inactive">RU</span>
                    </div>

                    <a href="/Home/Login" class="btn-login">Kirish</a>
                </div>

            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="glass-footer">
        <div class="container-fluid px-4">
            <div class="footer-inner">
                
                <a href="/" class="logo-text" style="margin-left: 0; font-size: 1.3rem;">
                    <img src="~/images/logo.png" alt="Logo" class="header-logo-img" style="height: 25px;" />
                    GEOPORTAL
                </a>

                <div class="footer-links">
                    <a href="/"><i class="bi bi-house"></i> Asosiy</a>
                    <a href="/Home/Report"><i class="bi bi-pencil-square"></i> Murojaat yo'llash</a>
                    <a href="#"><i class="bi bi-shield-check"></i> Maxfiylik siyosati</a>
                    <a href="tel:+998712000000"><i class="bi bi-telephone"></i> +998 71 200 00 00</a>
                </div>

                <p class="footer-copy">
                    &copy; 2026 GEOPORTAL. Barcha huquqlar himoyalangan.
                </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Тема
            const themeBtn = document.getElementById('theme-toggle');
            const themeIcon = document.getElementById('theme-icon');
            
            if (document.body.classList.contains('dark-mode')) {
                themeIcon.classList.replace('bi-moon-fill', 'bi-sun-fill');
            }

            themeBtn.addEventListener('click', () => {
                document.body.classList.toggle('dark-mode');
                if (document.body.classList.contains('dark-mode')) {
                    localStorage.setItem('geoportal_theme', 'dark');
                    themeIcon.classList.replace('bi-moon-fill', 'bi-sun-fill');
                } else {
                    localStorage.setItem('geoportal_theme', 'light');
                    themeIcon.classList.replace('bi-sun-fill', 'bi-moon-fill');
                }
            });

            // Язык
            const langToggle = document.getElementById('lang-toggle');
            const langUz = document.getElementById('lang-uz');
            const langRu = document.getElementById('lang-ru');

            let currentLang = localStorage.getItem('geoportal_lang') || 'UZ';
            if(currentLang === 'RU') {
                langUz.className = 'lang-inactive';
                langRu.className = 'lang-active';
            }

            langToggle.addEventListener('click', () => {
                if(langUz.classList.contains('lang-active')) {
                    langUz.className = 'lang-inactive';
                    langRu.className = 'lang-active';
                    localStorage.setItem('geoportal_lang', 'RU');
                } else {
                    langRu.className = 'lang-inactive';
                    langUz.className = 'lang-active';
                    localStorage.setItem('geoportal_lang', 'UZ');
                }
            });
        });
    </script>
</body>
</html>