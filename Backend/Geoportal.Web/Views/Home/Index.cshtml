                <div class="donor-leaderboard">
                    <h3 class="fw-black mb-5 text-dark text-center">Top investorlar va donorlar reytingi</h3>

                    <div class="donor-item">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-primary me-3 fs-5 py-2 px-3 rounded-circle">1</span>
                            <div class="fw-bold fs-4 text-dark">Davlat byudjeti</div>
                        </div>
                        <div class="text-end">
                            <div class="text-primary fw-900 fs-3">225.0</div>
                            <small class="text-muted fs-6">trln so'm</small>
                        </div>
                    </div>

                    <div class="donor-item">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-success me-3 fs-5 py-2 px-3 rounded-circle">2</span>
                            <div class="fw-bold fs-4 text-dark">Tiklanish jamg'armasi</div>
                        </div>
                        <div class="text-end">
                            <div class="text-success fw-900 fs-3">45.2</div>
                            <small class="text-muted fs-6">trln so'm</small>
                        </div>
                    </div>

                    <div class="donor-item">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-info me-3 fs-5 py-2 px-3 rounded-circle">3</span>
                            <div class="fw-bold fs-4 text-dark">Jahon Banki</div>
                        </div>
                        <div class="text-end">
                            <div class="text-info fw-900 fs-3">12.8</div>
                            <small class="text-muted fs-6">trln so'm</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-malumot" class="tool-content">
            <div class="mockup-box">
                <h2 class="fw-black">📊 Ma'lumotlar bazasi</h2>
                <p class="text-muted fs-5">Bu yerda barcha infratuzilma ob'ektlarining batafsil ro'yxati va jadvallari bo'ladi.</p>
            </div>
        </div>

        <div id="tab-grafik" class="tool-content">
            <div class="mockup-box">
                <h2 class="fw-black">📈 Analitika va Grafiklar</h2>
                <p class="text-muted fs-5">Hududlar kesimida mablag'larning sarflanishi va o'sish dinamikasi.</p>
            </div>
        </div>

        <div id="tab-solishtirish" class="tool-content">
            <div class="mockup-box">
                <h2 class="fw-black">⚖️ Hududlarni solishtirish</h2>
                <p class="text-muted fs-5">Ikki yoki undan ortiq hududni iqtisodiy va infratuzilma jihatdan taqqoslash vositasi.</p>
            </div>
        </div>

    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    function switchTab(tabId, clickedBtn) {
        document.querySelectorAll('.tool-tab-btn').forEach(btn => {
            btn.classList.remove('active', 'green-glow');
        });
        document.querySelectorAll('.tool-content').forEach(content => {
            content.classList.remove('active');
        });

        clickedBtn.classList.add('active', 'green-glow');
        document.getElementById(tabId).classList.add('active');

        if(tabId === 'tab-xarita' && map) {
            setTimeout(function(){ map.invalidateSize(); }, 100);
        }
    }

    var map;
    document.addEventListener("DOMContentLoaded", function () {
        map = L.map('map', {
            zoomControl: true,
            scrollWheelZoom: false
        }).setView([41.3775, 64.5853], 6);

        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var points = [
            { name: "Toshkent", coords: [41.2995, 69.2401], value: "4,231" },
            { name: "Samarqand", coords: [39.6270, 66.9750], value: "3,110" },
            { name: "Farg'ona", coords: [40.3842, 71.7843], value: "2,905" },
            { name: "Xorazm", coords: [41.5500, 60.6333], value: "1,450" }
        ];

        points.forEach(function (p) {
            var marker = L.circleMarker(p.coords, {
                radius: 10,
                fillColor: "#00FF88",
                color: "#0A56C4",
                weight: 2,
                opacity: 1,
                fillOpacity: 0.8
            }).addTo(map);

            marker.bindPopup("<b>" + p.name + "</b><br>Loyihalar: " + p.value);
        });
    });
</script>
