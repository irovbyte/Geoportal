@{
    ViewData["Title"] = "Kirish va Ro'yxatdan o'tish";
}

<style>
    /* АНИМИРОВАННЫЙ ФОН */
    .bg-shape-container {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        z-index: -1; overflow: hidden; pointer-events: none;
    }
    .bg-shape { position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.6; }
    @@keyframes moveShape1 { 0% { transform: translate3d(0, 0, 0) scale(1); } 100% { transform: translate3d(100px, 100px, 0) scale(1.2); } }
    @@keyframes moveShape2 { 0% { transform: translate3d(0, 0, 0) scale(1); } 100% { transform: translate3d(-100px, 150px, 0) scale(0.8); } }
    .shape-1 { width: 600px; height: 600px; background: #00FF88; top: -10%; left: -10%; animation: moveShape1 15s infinite alternate ease-in-out; }
    .shape-2 { width: 700px; height: 700px; background: #9D4EDD; bottom: -10%; right: -10%; animation: moveShape2 20s infinite alternate ease-in-out; }

    /* Обертка для центрирования карточки */
    .auth-page-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 160px);
        padding: 40px 20px;
    }

    /* АВТОРИЗАЦИОННАЯ КАРТОЧКА */
    .auth-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border-radius: 40px;
        padding: 50px 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.15);
        border: 1px solid rgba(255,255,255,0.6);
        width: 100%;
        max-width: 480px;
        position: relative;
        overflow: hidden;
        transition: background 0.6s ease, border-color 0.6s ease, box-shadow 0.6s ease;
        animation: cardAppear 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }

    @@keyframes cardAppear {
        0% { opacity: 0; transform: scale(0.9) translateY(30px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* ПЕРЕКЛЮЧАТЕЛЬ ВКЛАДОК (Вход / Регистрация) */
    .auth-tabs {
        display: flex;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 20px;
        padding: 6px;
        margin-bottom: 40px;
        position: relative;
        transition: background 0.6s ease;
    }
    .auth-tab-btn {
        flex: 1;
        text-align: center;
        padding: 12px 0;
        border-radius: 15px;
        font-weight: 800;
        font-size: 1rem;
        color: #6C7A9C;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }
    .auth-tab-btn.active {
        background: #ffffff;
        color: #1E2A47;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }

    /* ФОРМЫ И ПОЛЯ ВВОДА */
    .auth-form {
        display: none;
        opacity: 0;
        transform: translateX(20px);
        transition: all 0.4s ease;
    }
    .auth-form.active {
        display: block;
        opacity: 1;
        transform: translateX(0);
    }

    .form-group {
        margin-bottom: 25px;
        position: relative;
    }
    .form-group i {
        position: absolute;
        left: 25px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.2rem;
        color: #6C7A9C;
        transition: color 0.3s ease;
    }

    .gp-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.5);
        border: 2px solid rgba(0, 0, 0, 0.08);
        border-radius: 20px;
        padding: 18px 25px 18px 60px; /* Отступ слева для иконки */
        font-weight: 600;
        font-size: 1.05rem;
        color: #1E2A47;
        outline: none;
        transition: all 0.3s ease;
    }
    .gp-input:focus {
        background: #ffffff;
        border-color: #00FF88;
        box-shadow: 0 10px 25px rgba(0, 255, 136, 0.15);
    }
    .gp-input:focus + i, .gp-input:focus ~ i {
        color: #00FF88;
    }

    /* КНОПКА ОТПРАВКИ */
    .btn-auth {
        width: 100%;
        background: linear-gradient(90deg, #7000FF 0%, #4800FF 100%);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 18px;
        font-weight: 900;
        font-size: 1.15rem;
        box-shadow: 0 15px 35px rgba(72, 0, 255, 0.3);
        transition: all 0.3s ease;
        cursor: pointer;
        margin-top: 10px;
    }
    .btn-auth:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 45px rgba(72, 0, 255, 0.4);
    }

    /* =========================================
       ТЕМНАЯ ТЕМА (DARK MODE OVERRIDES)
       ========================================= */
    body.dark-mode .auth-card {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow: 0 40px 100px rgba(0,0,0,0.5);
    }
    
    body.dark-mode .auth-tabs { background: rgba(0, 0, 0, 0.3); }
    body.dark-mode .auth-tab-btn { color: #94a3b8; }
    body.dark-mode .auth-tab-btn.active {
        background: rgba(30, 41, 59, 0.9);
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    body.dark-mode .gp-input {
        background: rgba(15, 23, 42, 0.5);
        border-color: rgba(255, 255, 255, 0.1);
        color: #ffffff;
    }
    body.dark-mode .gp-input::placeholder { color: #64748b; }
    body.dark-mode .gp-input:focus {
        background: rgba(30, 41, 59, 0.9);
        border-color: #00FF88;
    }
    body.dark-mode .form-group i { color: #64748b; }
    body.dark-mode .gp-input:focus ~ i { color: #00FF88; }

</style>

<div class="bg-shape-container">
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>
</div>

<div class="auth-page-wrapper">
    <div class="auth-card">
        
        <h2 class="text-center fw-black mb-4">Xush kelibsiz!</h2>

        <div class="auth-tabs">
            <div class="auth-tab-btn active" onclick="toggleAuth('login')">Kirish</div>
            <div class="auth-tab-btn" onclick="toggleAuth('register')">Ro'yxatdan o'tish</div>
        </div>

        <form id="loginForm" class="auth-form active" method="POST" action="/Auth/Login">
            <input type="hidden" name="DeviceId" class="device-id-input" value="" />

            <div class="form-group">
                <input type="tel" name="PhoneNumber" class="gp-input" placeholder="+998 (__) ___-__-__" required>
                <i class="bi bi-telephone"></i>
            </div>
            
            <div class="form-group">
                <input type="password" name="Password" class="gp-input" placeholder="Parol" required>
                <i class="bi bi-lock"></i>
            </div>

            <div class="d-flex justify-content-end mb-4">
                <a href="#" class="text-decoration-none small text-muted">Parolni unutdingizmi?</a>
            </div>

            <button type="submit" class="btn-auth">Tizimga kirish</button>
        </form>

        <form id="registerForm" class="auth-form" method="POST" action="/Auth/Register">
            <input type="hidden" name="DeviceId" class="device-id-input" value="" />

            <div class="form-group">
                <input type="text" name="FullName" class="gp-input" placeholder="F.I.SH (To'liq ismingiz)" required>
                <i class="bi bi-person"></i>
            </div>

            <div class="form-group">
                <input type="tel" name="PhoneNumber" class="gp-input" placeholder="+998 (__) ___-__-__" required>
                <i class="bi bi-telephone"></i>
            </div>
            
            <div class="form-group">
                <input type="password" name="Password" class="gp-input" placeholder="Yangi parol o'ylab toping" required>
                <i class="bi bi-shield-lock"></i>
            </div>

            <button type="submit" class="btn-auth" style="background: linear-gradient(90deg, #00FF88 0%, #00D4FF 100%); color: #000;">
                Ro'yxatdan o'tish
            </button>
        </form>

    </div>
</div>

<script>
    // 1. Логика переключения вкладок с плавной анимацией
    function toggleAuth(type) {
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');
        const tabs = document.querySelectorAll('.auth-tab-btn');

        // Сброс активных классов
        tabs.forEach(t => t.classList.remove('active'));
        loginForm.style.opacity = '0';
        registerForm.style.opacity = '0';

        setTimeout(() => {
            loginForm.classList.remove('active');
            registerForm.classList.remove('active');

            if (type === 'login') {
                tabs[0].classList.add('active');
                loginForm.classList.add('active');
                setTimeout(() => loginForm.style.opacity = '1', 50);
            } else {
                tabs[1].classList.add('active');
                registerForm.classList.add('active');
                setTimeout(() => registerForm.style.opacity = '1', 50);
            }
        }, 300); // Ждем пока исчезнет старая форма
    }

    // 2. Логика генерации уникального DeviceId
    // Если его нет в localStorage браузера - создаем и сохраняем
    document.addEventListener('DOMContentLoaded', () => {
        let deviceId = localStorage.getItem('gp_device_id');
        
        if (!deviceId) {
            // Генерируем случайный UUID v4 для устройства
            deviceId = crypto.randomUUID ? crypto.randomUUID() : 'dev-' + Math.random().toString(36).substr(2, 9);
            localStorage.setItem('gp_device_id', deviceId);
        }

        // Вставляем этот ID во все скрытые поля обеих форм
        document.querySelectorAll('.device-id-input').forEach(input => {
            input.value = deviceId;
        });
        
        console.log("Current Device ID generated for Backend:", deviceId);
    });
</script>