@{
    ViewData["Title"] = "Grafik vositalar";
}

<style>
    /* =========================================
       СТИЛИ ДЛЯ СТРАНИЦЫ ГРАФИКОВ (PDF PAGE 5)
       ========================================= */
    .top-sub-nav {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(15px);
        border-radius: 50px;
        padding: 5px;
        display: inline-flex;
        gap: 5px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        overflow-x: auto;
        max-width: 100%;
        scrollbar-width: none;
        /* Скрываем скролл */
    }


    .top-sub-nav::-webkit-scrollbar {
        display: none;
    }

    .sub-nav-btn {
        background: transparent;
        border: none;
        border-radius: 40px;
        padding: 10px 20px;
        font-weight: 700;
        color: #444;
        white-space: nowrap;
        transition: all 0.3s;
    }

    .sub-nav-btn.active {
        background: white;
        color: #000;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    /* Легенда */
    .legend-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: inline-block;
    }

    .color-optik {
        background: #00FF88;
    }

    .color-no-internet {
        background: #00E5FF;
    }

    .color-mobil {
        background: #0A56C4;
    }

    /* Контейнер графика */
    .chart-container {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        border-radius: 24px;
        padding: 30px;
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.03);
        margin-top: 20px;
    }

    .chart-wrapper {
        display: flex;
        align-items: flex-end;
        height: 350px;
        border-left: 2px solid rgba(0, 0, 0, 0.1);
        border-bottom: 2px solid rgba(0, 0, 0, 0.1);
        padding-left: 10px;
        gap: 25px;
        overflow-x: auto;
        padding-bottom: 5px;
        scrollbar-width: none;
    }

    .chart-wrapper::-webkit-scrollbar {
        display: none;
    }

    /* Ось Y */
    .y-axis {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 350px;
        text-align: right;
        padding-right: 15px;
        font-weight: 700;
        color: #555;
        font-size: 0.85rem;
        margin-left: -55px;
        /* Выносим за линию графика */
        width: 40px;
    }

    /* Столбцы графика */
    .bar-group {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        /* Столбцы растут снизу вверх */
        align-items: center;
        height: 100%;
        min-width: 45px;
        position: relative;
    }

    .bar-label {
        position: absolute;
        bottom: -30px;
        font-size: 0.75rem;
        font-weight: 700;
        color: #555;
        white-space: nowrap;
    }

    /* Сегменты внутри столбца */
    .bar-segment {
        width: 100%;
        transition: height 0.5s ease;
    }

    .bar-segment:first-child {
        border-radius: 6px 6px 0 0;
    }

    /* Анимация роста графика */
    .animate-grow {
        transform-origin: bottom;
        animation: growUp 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        opacity: 0;
    }

    @@keyframes growUp {
        0% {
            transform: scaleY(0);
            opacity: 0;
        }

        100% {
            transform: scaleY(1);
            opacity: 1;
        }
    }

    /* Анимация появления контента */
    .animate-fade-up {
        opacity: 0;
        animation: fadeUpAnim 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }

    @@keyframes fadeUpAnim {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>



<div class="mb-4 d-flex align-items-center animate-fade-up" style="animation-delay: 0.1s;">
    <a href="/" class="text-decoration-none fw-bold text-dark fs-3 me-3 hover-scale transition">←</a>
    <h2 class="fw-bolder text-dark mb-0">Maktablar</h2>
</div>

<div class="top-sub-nav mb-4 animate-fade-up" style="animation-delay: 0.2s;">
    <button class="sub-nav-btn active">Internet</button>
    <button class="sub-nav-btn">Ichimlik suvi</button>
    <button class="sub-nav-btn">Sig'im va umimy talaba soni</button>
    <button class="sub-nav-btn">Jadval</button>
    <button class="sub-nav-btn">Xarita</button>
</div>

