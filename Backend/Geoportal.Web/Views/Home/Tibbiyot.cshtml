@{
    ViewData["Title"] = "Tibbiyot";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    /* 1. Глобальный фон */
    body {
        background-color: #0A56C4;
        background-image: linear-gradient(135deg, #0A56C4 0%, #158296 50%, #19A332 100%) !important;
        background-attachment: fixed !important;
        font-family: 'Inter', sans-serif;
        -webkit-font-smoothing: antialiased;
        position: relative;
        overflow-x: hidden;
    }

    .bg-shape-container { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1; pointer-events: none; }
    .bg-shape { position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.6; }

    @@keyframes moveShape1 { 0% { transform: translate3d(0,0,0) scale(1); } 100% { transform: translate3d(-50px, -150px, 0) scale(0.9); } }
    @@keyframes moveShape2 { 0% { transform: translate3d(0,0,0) scale(1); } 100% { transform: translate3d(100px, -100px, 0) scale(1.3); } }

    .shape-1 { width: 700px; height: 700px; background: #00FF88; top: -10%; left: -10%; animation: moveShape1 20s infinite alternate ease-in-out; }
    .shape-2 { width: 900px; height: 900px; background: #9D4EDD; bottom: -20%; right: -10%; animation: moveShape2 25s infinite alternate ease-in-out; }

    .gp-container {
        width: 96%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 10px 80px 10px;
    }

    /* 2. Шапка категории */
    .category-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 40px;
        position: relative;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 25px;
    }

    .back-btn {
        width: 55px; height: 55px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white; text-decoration: none; font-size: 1.5rem;
        transition: all 0.3s ease; box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
    .back-btn:hover { background: white; color: #0A56C4; transform: translateX(-5px); }

    .category-title {
        font-weight: 900; font-size: clamp(3rem, 5vw, 4.5rem);
        color: white; margin: 0; letter-spacing: -1px;
        text-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .header-right-icon {
        font-size: 8rem;
        opacity: 0.15;
        position: absolute;
        right: 50px;
        top: -20px;
        transform: rotate(10deg);
        pointer-events: none;
    }

    /* 3. ПЛАВАЮЩИЕ ТАБЫ */
    .pills-nav {
        display: flex;
        gap: 10px;
        margin-bottom: -15px;
        position: relative;
        z-index: 10;
        flex-wrap: wrap;
        padding-left: 40px;
    }

    .tab-pill {
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.8);
        padding: 16px 35px 25px 35px;
        border-radius: 30px 30px 0 0;
        font-weight: 800;
        font-size: 1.1rem;
        color: #1E2A47;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 15px;
    }

    .tab-pill:hover {
        background: rgba(255, 255, 255, 0.8);
    }

    .tab-pill.active {
        background: #ffffff;
        color: #000;
        border-bottom-color: #ffffff;
        margin-top: 0;
        padding-bottom: 30px;
        box-shadow: 0 -10px 20px rgba(0, 0, 0, 0.05);
    }

    /* 4. ГЛАВНАЯ ПАНЕЛЬ ДЛЯ ГРАФИКОВ */
    .glass-content-panel {
        background: #ffffff;
        border-radius: 40px;
        padding: 50px;
        box-shadow: 0 40px 80px rgba(0,0,0,0.15);
        border: 2px solid rgba(255,255,255,0.9);
        position: relative;
        z-index: 5;
        min-height: 600px;
    }

    .cat-content { display: none; opacity: 0; }
    .cat-content.active { display: block; animation: fadeInTab 0.5s ease forwards; }

    @@keyframes fadeInTab {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    .chart-wrapper {
        width: 100%;
        height: 500px;
        margin-top: 20px;
    }

    .mockup-box {
        background: #F8F9FA; border-radius: 30px; padding: 60px; text-align: center;
        border: 2px dashed #CED4DA; min-height: 400px; display: flex; flex-direction: column;
        justify-content: center; align-items: center; margin-top: 30px;
    }
</style>

<div class="bg-shape-container">
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>
</div>

<div class="gp-container">

    <div class="category-header animate-fade-up">
        <div class="header-left">
            <a href="/" class="back-btn">←</a>
            <h1 class="category-title">Tibbiyot</h1>
        </div>
        <div class="header-right-icon">🏥</div>
    </div>

    <div class="pills-nav animate-fade-up" style="animation-delay: 0.1s;">
        <div class="tab-pill active" onclick="switchCategoryTab('tab-muassasa', this)">Muassasa turlari</div>
        <div class="tab-pill" onclick="switchCategoryTab('tab-tez-yordam', this)">Tez tibbiy yordam</div>
        <div class="tab-pill" onclick="switchCategoryTab('tab-uskuna', this)">Tibbiy uskunalar</div>
        <div class="tab-pill" onclick="switchCategoryTab('tab-jadval', this)">Jadval</div>
        <div class="tab-pill" onclick="switchCategoryTab('tab-xarita', this)">Xarita</div>
    </div>

    <div class="glass-content-panel animate-fade-up" style="animation-delay: 0.2s;">

        <div id="tab-muassasa" class="cat-content active">
            <div class="chart-wrapper">
                <canvas id="tibbiyotChart"></canvas>
            </div>
        </div>

        <div id="tab-tez-yordam" class="cat-content">
            <div class="mockup-box">
                <h2 class="fw-black">🚑 Tez tibbiy yordam mashinalari</h2>
                <p class="text-muted fs-5">Hududlar kesimida tez yordam brigadalari va avtotransport bilan ta'minlanganlik holati.</p>
            </div>
        </div>

        <div id="tab-uskuna" class="cat-content">
            <div class="mockup-box">
                <h2 class="fw-black">🩺 Zamonaviy tibbiy uskunalar</h2>
                <p class="text-muted fs-5">Kasalxonalarning MRT, UTT va boshqa zarur apparaturalar bilan ta'minlanish darajasi.</p>
            </div>
        </div>

        <div id="tab-jadval" class="cat-content">
            <div class="mockup-box">
                <h2 class="fw-black">📋 Batafsil Jadval</h2>
                <p class="text-muted fs-5">Barcha tibbiyot ob'ektlari bo'yicha yig'ma ma'lumotlar.</p>
            </div>
        </div>

        <div id="tab-xarita" class="cat-content">
            <div class="mockup-box" style="border-style: solid; background: #E9ECEF;">
                <h2 class="fw-black">🗺️ Interaktiv Xarita</h2>
                <p class="text-muted fs-5">Poliklinika va kasalxonalar joylashuvi.</p>
            </div>
        </div>

    </div>
</div>

<script>
    // Логика переключения
    function switchCategoryTab(tabId, clickedBtn) {
        document.querySelectorAll('.tab-pill').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.cat-content').forEach(content => content.classList.remove('active'));
        clickedBtn.classList.add('active');
        document.getElementById(tabId).classList.add('active');
    }

    // График для медицины
    document.addEventListener("DOMContentLoaded", function () {
        const ctx = document.getElementById('tibbiyotChart').getContext('2d');

        const greenGradient = ctx.createLinearGradient(0, 0, 0, 400);
        greenGradient.addColorStop(0, '#00FF88');
        greenGradient.addColorStop(1, 'rgba(0, 255, 136, 0.1)');

        const data = {
            labels: ['Andijon', 'Buxoro', 'Farg\'ona', 'Jizzax', 'Namangan', 'Navoiy', 'Qashqadaryo', 'Qoraqalpog\'iston', 'Samarqand', 'Sirdaryo', 'Surxondaryo', 'Toshkent sh', 'Toshkent v', 'Xorazm'],
            datasets: [
                {
                    label: 'Kasalxonalar',
                    data: [35, 28, 42, 20, 38, 18, 40, 25, 45, 15, 30, 50, 42, 22],
                    backgroundColor: '#0A56C4',
                    borderRadius: {topLeft: 5, topRight: 5, bottomLeft: 0, bottomRight: 0}
                },
                {
                    label: 'QVP / QOP (Qishloq vrachlik punktlari)',
                    data: [150, 110, 180, 90, 140, 70, 200, 130, 210, 60, 160, 20, 180, 100],
                    backgroundColor: '#00D4FF',
                },
                {
                    label: 'Poliklinikalar',
                    data: [80, 65, 95, 45, 85, 35, 100, 60, 110, 30, 80, 120, 105, 55],
                    backgroundColor: greenGradient,
                }
            ]
        };

        const config = {
            type: 'bar',
            data: data,
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top', align: 'start', labels: { usePointStyle: true, boxWidth: 10, font: { family: 'Inter', size: 14, weight: 'bold' }, color: '#1E2A47' } },
                    tooltip: { backgroundColor: 'rgba(30, 42, 71, 0.9)', titleFont: { size: 14 }, bodyFont: { size: 14 }, padding: 15, cornerRadius: 10 }
                },
                scales: {
                    x: { stacked: true, grid: { display: false, drawBorder: false }, ticks: { font: { family: 'Inter', weight: 'bold', size: 11 }, color: '#1E2A47' } },
                    y: { stacked: true, grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false }, ticks: { font: { family: 'Inter', weight: 'bold' }, color: '#8E9AAF', stepSize: 50 } }
                }
            }
        };

        new Chart(ctx, config);
    });
</script>
