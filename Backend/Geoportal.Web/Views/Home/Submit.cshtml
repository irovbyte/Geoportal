@{
    ViewData["Title"] = "Murojaat qabul qilindi";
}

<style>
    /* Анимированные сферы на фоне */
    .bg-shape-container {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: -1;
        pointer-events: none;
    }
    .bg-shape { position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.6; }

    @@keyframes moveShape {
        0% { transform: translate3d(0,0,0) scale(1); }
        100% { transform: translate3d(100px, 100px, 0) scale(1.2); }
    }
    .shape-1 { width: 600px; height: 600px; background: #00FF88; top: -10%; left: -10%; animation: moveShape 15s infinite alternate ease-in-out; }
    .shape-2 { width: 700px; height: 700px; background: #9D4EDD; bottom: -10%; right: -10%; animation: moveShape 20s infinite alternate-reverse ease-in-out; }

    /* Обертка для центрирования на странице без поломки Layout */
    .success-page-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 180px); /* Высота экрана минус шапка и футер */
        padding: 40px 20px;
    }

    /* 2. Карточка подтверждения */
    .success-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border-radius: 50px;
        padding: 60px 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.2);
        border: 1px solid rgba(255,255,255,0.6);
        text-align: center;
        max-width: 600px;
        width: 100%;
        animation: cardAppear 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        transition: background 0.6s ease, border-color 0.6s ease, box-shadow 0.6s ease;
    }

    @@keyframes cardAppear {
        0% { opacity: 0; transform: scale(0.8) translateY(50px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* 3. Анимированная галочка */
    .success-icon-wrapper {
        width: 120px;
        height: 120px;
        background: #00FF88;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px auto;
        box-shadow: 0 15px 35px rgba(0, 255, 136, 0.4);
        position: relative;
    }

    .checkmark {
        width: 60px;
        height: 30px;
        border-left: 8px solid #0A56C4;
        border-bottom: 8px solid #0A56C4;
        transform: rotate(-45deg) translate(5px, -5px);
        animation: checkAnim 0.5s 0.6s both;
    }

    @@keyframes checkAnim {
        0% { opacity: 0; transform: rotate(-45deg) scale(0.5); }
        100% { opacity: 1; transform: rotate(-45deg) scale(1); }
    }

    /* 4. Тексты */
    .status-badge {
        background: rgba(10, 86, 196, 0.1);
        color: #0A56C4;
        padding: 8px 20px;
        border-radius: 100px;
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
        display: inline-block;
        transition: background 0.6s ease, color 0.6s ease;
    }

    .success-title {
        font-weight: 900;
        font-size: 2.5rem;
        color: #1E2A47;
        margin-bottom: 20px;
        line-height: 1.2;
    }

    .success-desc {
        color: #6C7A9C;
        font-size: 1.2rem;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    /* 5. Кнопка возврата */
    .btn-home {
        background: linear-gradient(90deg, #0A56C4 0%, #2575FC 100%);
        color: white;
        border: none;
        border-radius: 100px;
        padding: 18px 50px;
        font-weight: 800;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
        box-shadow: 0 15px 30px rgba(37, 117, 252, 0.3);
    }

    .btn-home:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(37, 117, 252, 0.4);
        color: white;
    }

    /* =========================================
       ТЕМНАЯ ТЕМА ДЛЯ ЭТОЙ СТРАНИЦЫ
       ========================================= */
    body.dark-mode .success-card {
        background: rgba(15, 23, 42, 0.6);
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow: 0 40px 100px rgba(0,0,0,0.4);
    }

    body.dark-mode .status-badge {
        background: rgba(0, 255, 136, 0.15);
        color: #00FF88;
    }
</style>

<div class="bg-shape-container">
    <div class="bg-shape shape-1"></div>
    <div class="bg-shape shape-2"></div>
</div>

<div class="success-page-wrapper">
    <div class="success-card">
        <div class="success-icon-wrapper">
            <div class="checkmark"></div>
        </div>

        <div class="status-badge">Ishlov berilmoqda</div>

        <h1 class="success-title">Ma’lumotlaringiz qabul qilindi!</h1>

        <p class="success-desc">
            Yuborgan ma'lumotingiz tizim mutaxassislari tomonidan ko'rib chiqilmoqda.
            Tez orada natijalarni "Natijalar" bo'limida ko'rishingiz mumkin.
        </p>

        <a href="/" class="btn-home">Bosh sahifaga qaytish</a>
    </div>
</div>